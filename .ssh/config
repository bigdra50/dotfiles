# ~/.ssh/config (bigdra50/dotfiles 管理)
#
# マシン固有・プロファイル固有のホストはこのファイルに書かず config.d/ に置く:
#   - プロファイル固有ホスト: 別の private な dotfiles の setup.sh が config.d/*.conf を配備
#   - マシン固有ホスト      : config.d/local.conf に手書きする (git 管理外)
Include config.d/*.conf

# GitHub personal account (bigdra50)
# .gitconfig-bigdra50 の insteadOf が bigdra50 リポジトリの URL をこの Host に書き換える
Host github.com.bigdra50
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal_gh
  IdentitiesOnly yes

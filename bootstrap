#!/usr/bin/env bash
# =============================================================================
# Dotfiles Bootstrap Script
# =============================================================================
# Sets up a new machine from scratch: git -> clone -> mise -> setup
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/bigdra50/dotfiles/main/bootstrap | bash
#   DOTFILES_DIR=$HOME/custom/path bash bootstrap

set -euo pipefail

DOTFILES_REPO="https://github.com/bigdra50/dotfiles.git"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dev/github.com/bigdra50/dotfiles}"

_info()    { echo -e "\033[0;34m==>\033[0m $1"; }
_success() { echo -e "\033[0;32m[OK]\033[0m $1"; }
_error()   { echo -e "\033[0;31mX\033[0m $1" >&2; }

# ---- 1. git ----

if ! command -v git &>/dev/null; then
    _info "Installing git..."
    case "$(uname -s)" in
        Darwin*)
            xcode-select --install 2>/dev/null || true
            until xcode-select -p &>/dev/null; do sleep 5; done
            ;;
        Linux*)
            if command -v apt-get &>/dev/null; then
                sudo apt-get update && sudo apt-get install -y git curl build-essential zsh
            elif command -v dnf &>/dev/null; then
                sudo dnf install -y git curl gcc gcc-c++ make zsh
            elif command -v pacman &>/dev/null; then
                sudo pacman -Syu --noconfirm git curl base-devel zsh
            else
                _error "No supported package manager found"
                exit 1
            fi
            ;;
        *) _error "Unsupported OS"; exit 1 ;;
    esac
fi
_success "git $(git --version | awk '{print $3}')"

# ---- 2. Clone/update repo ----

if [[ -d "$DOTFILES_DIR/.git" ]]; then
    _info "Updating existing repo..."
    cd "$DOTFILES_DIR"
    git pull --rebase origin main || _info "Pull failed, continuing with existing version"
else
    _info "Cloning dotfiles..."
    mkdir -p "$(dirname "$DOTFILES_DIR")"
    git clone "$DOTFILES_REPO" "$DOTFILES_DIR"
fi
cd "$DOTFILES_DIR"
_success "Repo ready at $DOTFILES_DIR"

# ---- 3. mise ----

if ! command -v mise &>/dev/null; then
    _info "Installing mise..."
    curl https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
fi
mise trust "$DOTFILES_DIR/.config/mise/config.toml" 2>/dev/null || true
mise trust "$DOTFILES_DIR/mise.toml" 2>/dev/null || true
_success "mise $(mise --version)"

# ---- 4. Setup ----

_info "Running dotfiles setup..."
INTERACTIVE=false mise run setup

echo ""
_success "Bootstrap complete!"
echo ""
echo "  Next steps:"
echo "    1. Restart your shell or: source ~/.zshrc"
echo "    2. Customize: ~/.zshrc_local, ~/.gitconfig_local"
echo ""

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 1000,
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_MICROCOMPACT": "1",
    "ENABLE_BACKGROUND_TASKS": "1",
    "FORCE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(codex:*)",
      "Bash(codex exec:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(bat:*)",
      "Bash(lsd:*)",
      "Bash(dust:*)",
      "Bash(procs:*)",
      "Bash(delta:*)",
      "Bash(jq:*)",
      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(env:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(mise:*)",
      "Bash(cargo --version:*)",
      "Bash(go version:*)",
      "Bash(node --version:*)",
      "Bash(python --version:*)",
      "Bash(ruby --version:*)",
      "Bash(tokei:*)",
      "Bash(hyperfine:*)",
      "Bash(btm:*)",
      "Bash(zoxide:*)",
      "Bash(hexyl:*)",
      "Bash(xh:*)",
      "Bash(gh repo:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(ifconfig:*)",
      "Bash(ip:*)",
      "Bash(netstat:*)",
      "Bash(ss:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(df:*)",
      "Bash(free:*)",
      "Bash(top -l:*)",
      "Bash(uptime:*)",
      "Bash(id:*)",
      "Bash(zipinfo:*)",
      "Bash(unzip -l:*)",
      "Bash(tar -tf:*)",
      "Bash(tar -tvf:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(cmp:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(readlink:*)",
      "Bash(md5:*)",
      "Bash(shasum:*)",
      "Bash(sha256sum:*)",
      "Bash(man:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(write:/tmp/*)"
    ],
    "deny": [
      "Bash (sudo:*)",
      "Bash (rm--rf: :*)",
      "Bash (git push:*) ",
      "Bash (git reset:*)",
      "Bash (git rebase:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Read (.env.*)",
      "Read (id_rsa)",
      "Read (id_ed25519)",
      "Read (**/*token*) ",
      "Write(.env*)",
      "Write (**/secrets/**)",
      "Bash (curl:*) ",
      "Bash (wget :*) ",
      "Bash (nc:*) ",
      "Bash (npm uninstall:*)",
      "Bash (npm remove: :*)",
      "Bash(psql: :*) ",
      "Bash (mysql:*)",
      "Bash (mongod:*) ",
      "NotebookEdit"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type stop",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/save-history-on-compact.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type idle_prompt",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type permission_prompt",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "unity@upfrontier-lab": false,
    "session@bigdra50": true,
    "git-workflow@bigdra50": true,
    "document-skills@anthropic-agent-skills": true,
    "unity-dev@bigdra50": false,
    "unity-cli@unity-tools": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754086968953
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}

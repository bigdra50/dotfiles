{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_MICROCOMPACT": "1",
    "ENABLE_BACKGROUND_TASKS": "1",
    "FORCE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_WORKFLOWS": "1"
  },
  "includeCoAuthoredBy": false,
  "attribution": {
    "sessionUrl": false
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(codex:*)",
      "Bash(codex exec:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(bat:*)",
      "Bash(lsd:*)",
      "Bash(dust:*)",
      "Bash(procs:*)",
      "Bash(delta:*)",
      "Bash(jq:*)",
      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(env:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(mise:*)",
      "Bash(cargo --version:*)",
      "Bash(go version:*)",
      "Bash(node --version:*)",
      "Bash(python --version:*)",
      "Bash(ruby --version:*)",
      "Bash(tokei:*)",
      "Bash(hyperfine:*)",
      "Bash(btm:*)",
      "Bash(zoxide:*)",
      "Bash(hexyl:*)",
      "Bash(xh:*)",
      "Bash(gh repo:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(ifconfig:*)",
      "Bash(ip:*)",
      "Bash(netstat:*)",
      "Bash(ss:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(df:*)",
      "Bash(free:*)",
      "Bash(top -l:*)",
      "Bash(uptime:*)",
      "Bash(id:*)",
      "Bash(zipinfo:*)",
      "Bash(unzip -l:*)",
      "Bash(tar -tf:*)",
      "Bash(tar -tvf:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(cmp:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(readlink:*)",
      "Bash(md5:*)",
      "Bash(shasum:*)",
      "Bash(sha256sum:*)",
      "Bash(man:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(write:/tmp/*)",
      "Bash(fc-list:*)",
      "Bash(system_profiler:*)",
      "WebFetch(domain:syu-m-5151.hatenablog.com)",
      "Bash(grep:*)",
      "Read(/Users/USER/Documents/Obsidian Vault/daily/*)",
      "Edit(/Users/USER/Documents/Obsidian Vault/daily/*)",
      "Write(/Users/USER/Documents/Obsidian Vault/daily/*)"
    ],
    "deny": [
      "Bash(sudo:*)"
    ],
    "ask": [
      "Bash(rm -rf:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": []
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type stop",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/open-impl-notes.sh",
            "statusMessage": "implementation-notes.html を確認しています",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type permission_prompt",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type idle_prompt",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type elicitation_dialog",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | while IFS= read -r cmd; do printf ': %s:0;%s\\n' \"$(date +%s)\" \"$cmd\"; done >> ${HOME}/.zsh_history"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "session-topic-capture UserPromptSubmit"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/userpromptsubmit-compaction-recovery.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/userpromptsubmit-compact-prep-reminder.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "session-topic-capture PreCompact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/compaction-recovery.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "session-topic-capture SessionEnd"
          },
          {
            "type": "command",
            "command": "~/.local/share/mise/shims/sessions index 2>/dev/null || true",
            "statusMessage": "セッションインデックスを更新しています",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "git-workflow@bigdra50": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "unity-dev@bigdra50": true,
    "codex@openai-codex": false,
    "oh-my-mermaid@oh-my-mermaid": true,
    "figma@claude-plugins-official": true,
    "everything-evenhub@everything-evenhub": true,
    "unity-coding-skills@bigdra50-unity-coding-skills": true,
    "understand-anything@understand-anything": true,
    "watch@claude-video": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "oh-my-mermaid": {
      "source": {
        "source": "github",
        "repo": "oh-my-mermaid/oh-my-mermaid"
      }
    },
    "everything-evenhub": {
      "source": {
        "source": "github",
        "repo": "even-realities/everything-evenhub"
      }
    },
    "bigdra50-unity-coding-skills": {
      "source": {
        "source": "github",
        "repo": "bigdra50/unity-coding-skills"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Egonex-AI/Understand-Anything"
      }
    },
    "claude-video": {
      "source": {
        "source": "github",
        "repo": "bradautomates/claude-video"
      }
    }
  },
  "viewMode": "verbose",
  "language": "Japanese",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "127.0.0.1:*",
        "localhost:*",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com"
      ]
    },
    "excludedCommands": [
      "vpn *",
      "u *",
      "gh *"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "ultracode": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "verbose": true,
  "autoCompactEnabled": true,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "voiceEnabled": true,
  "mcpServers": {}
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 1000,
  "env": {
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_MICROCOMPACT": "1",
    "ENABLE_BACKGROUND_TASKS": "1",
    "FORCE_AUTO_BACKGROUND_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(codex:*)",
      "Bash(codex exec:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(bat:*)",
      "Bash(lsd:*)",
      "Bash(dust:*)",
      "Bash(procs:*)",
      "Bash(delta:*)",
      "Bash(jq:*)",
      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(env:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(mise:*)",
      "Bash(cargo --version:*)",
      "Bash(go version:*)",
      "Bash(node --version:*)",
      "Bash(python --version:*)",
      "Bash(ruby --version:*)",
      "Bash(tokei:*)",
      "Bash(hyperfine:*)",
      "Bash(btm:*)",
      "Bash(zoxide:*)",
      "Bash(hexyl:*)",
      "Bash(xh:*)",
      "Bash(gh repo:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(ifconfig:*)",
      "Bash(ip:*)",
      "Bash(netstat:*)",
      "Bash(ss:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(df:*)",
      "Bash(free:*)",
      "Bash(top -l:*)",
      "Bash(uptime:*)",
      "Bash(id:*)",
      "Bash(zipinfo:*)",
      "Bash(unzip -l:*)",
      "Bash(tar -tf:*)",
      "Bash(tar -tvf:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(cmp:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(readlink:*)",
      "Bash(md5:*)",
      "Bash(shasum:*)",
      "Bash(sha256sum:*)",
      "Bash(man:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(write:/tmp/*)"
    ],
    "deny": [
      "Bash (sudo:*)",
      "Bash (rm--rf: :*)",
      "Bash (git push:*) ",
      "Bash (git reset:*)",
      "Bash (git rebase:*)",
      "Bash(git add .:*)",
      "Bash(git add -A:*)",
      "Read (.env.*)",
      "Read (id_rsa)",
      "Read (id_ed25519)",
      "Read (**/*token*) ",
      "Write(.env*)",
      "Write (**/secrets/**)",
      "Bash (curl:*) ",
      "Bash (wget :*) ",
      "Bash (nc:*) ",
      "Bash (npm uninstall:*)",
      "Bash (npm remove: :*)",
      "Bash(psql: :*) ",
      "Bash (mysql:*)",
      "Bash (mongod:*) ",
      "NotebookEdit"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": []
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type stop",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type permission_prompt",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type idle_prompt",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/notify.py --type elicitation_dialog",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | while IFS= read -r cmd; do printf ': %s:0;%s\\n' \"$(date +%s)\" \"$cmd\"; done >> ${HOME}/.zsh_history"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v session-topic-capture >/dev/null && session-topic-capture UserPromptSubmit"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v session-topic-capture >/dev/null && session-topic-capture PreCompact"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v session-topic-capture >/dev/null && session-topic-capture SessionEnd"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": false,
    "frontend-design@claude-code-plugins": true,
    "git-workflow@bigdra50": true,
    "example-skills@anthropic-agent-skills": true,
    "claude-md-management@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "unity-dev@bigdra50": true,
    "codex@openai-codex": true,
    "oh-my-mermaid@oh-my-mermaid": true,
    "copilot@ORG-copilot": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "oh-my-mermaid": {
      "source": {
        "source": "github",
        "repo": "oh-my-mermaid/oh-my-mermaid"
      }
    }
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "127.0.0.1:*",
        "localhost:*",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com"
      ]
    },
    "excludedCommands": ["vpn *", "u *", "gh *"]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754086968953
  },
  "mcpServers": {}
}

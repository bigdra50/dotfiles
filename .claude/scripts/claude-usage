#!/usr/bin/env bash
# claude-usage — Claude Code の利用枠(5h / weekly / Fable等の scoped)を
# 単一の共有キャッシュ経由で全セッションに配る。stale-while-revalidate + mkdir ロック。
#
#   claude-usage statusline   # 常時表示用の1行(古くても即返す。期限切れなら裏で更新)
#   claude-usage hook         # UserPromptSubmit用。残量デルタゲートを超えた時だけ注入文を出す
#   claude-usage raw          # 生JSON(デバッグ)
#   claude-usage refresh      # 実fetch(通常は上記が裏で自動起動。launchd等からも可)
#
# 非公式API (api.anthropic.com/api/oauth/usage)。token は Keychain/credentials から
# 実行時に読むだけで、この外には出さない。予告なく壊れうる。

set -uo pipefail

TTL=120                                    # キャッシュ鮮度(秒)
DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude-usage"
CACHE="$DIR/usage.json"
LOCK="$DIR/refresh.lock.d"
SEEN="$DIR/seen"                            # セッション別 注入状態
LOCK_STALE=60
mkdir -p "$DIR" "$SEEN"

now(){ date +%s; }
mtime(){ stat -f %m "$1" 2>/dev/null || stat -c %Y "$1" 2>/dev/null || echo 0; }

read_token(){
  local t
  t=$(python3 -c "import json;print(json.load(open('$HOME/.claude/.credentials.json'))['claudeAiOauth']['accessToken'])" 2>/dev/null)
  [ -n "$t" ] && { printf '%s' "$t"; return; }
  t=$(security find-generic-password -s 'Claude Code-credentials' -w 2>/dev/null \
        | python3 -c "import json,sys;print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])" 2>/dev/null)
  printf '%s' "$t"
}

do_refresh(){
  if ! mkdir "$LOCK" 2>/dev/null; then
    local age=$(( $(now) - $(mtime "$LOCK") ))
    if [ "$age" -gt "$LOCK_STALE" ]; then rmdir "$LOCK" 2>/dev/null; mkdir "$LOCK" 2>/dev/null || return 0; else return 0; fi
  fi
  trap 'rmdir "$LOCK" 2>/dev/null' EXIT
  local ver token resp
  ver=$(claude --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1); ver=${ver:-1.0.0}
  token=$(read_token); [ -z "$token" ] && return 0
  resp=$(curl -sS --max-time 6 "https://api.anthropic.com/api/oauth/usage" \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    -H "User-Agent: claude-code/$ver" \
    -H "Content-Type: application/json" 2>/dev/null)
  printf '%s' "$resp" | python3 -c "import json,sys;d=json.load(sys.stdin);sys.exit(0 if 'limits' in d else 1)" 2>/dev/null \
    && { printf '%s' "$resp" > "$CACHE.tmp" && mv -f "$CACHE.tmp" "$CACHE"; }
}

ensure_fresh(){
  local stale=1
  [ -f "$CACHE" ] && [ $(( $(now) - $(mtime "$CACHE") )) -lt "$TTL" ] && stale=0
  [ "$stale" -eq 1 ] && ( "$0" refresh >/dev/null 2>&1 & )
  return 0
}

session_id(){  # UserPromptSubmit の stdin JSON から session_id。無ければ env/manual
  local sid=""
  if [ ! -t 0 ]; then
    sid=$(python3 -c "import json,sys
try: print((json.load(sys.stdin).get('session_id') or '')[:64])
except Exception: pass" 2>/dev/null)
  fi
  [ -z "$sid" ] && sid="${CLAUDE_SESSION_ID:-manual}"
  printf '%s' "$sid" | tr -c 'A-Za-z0-9._-' '_'
}

cmd="${1:-statusline}"
case "$cmd" in
  refresh)    do_refresh ;;
  statusline) ensure_fresh; STATE="" python3 - statusline "$CACHE" "" <<'PY'
import json,sys,datetime
mode,path=sys.argv[1],sys.argv[2]
try: d=json.load(open(path))
except Exception: print("usage …"); sys.exit(0)
lims=d.get("limits") or []
def pick(k):
    return next((l for l in lims if l.get("kind")==k), None)
def scoped(): return [l for l in lims if l.get("group")=="weekly" and l.get("scope")]
def pc(l): return int(round(l.get("percent",0)))
def name(l):
    return (((l.get("scope") or {}).get("model") or {}).get("display_name")) or "?"
mark={"normal":"","warning":"⚠","critical":"⛔"}
sess=pick("session"); wk=pick("weekly_all")
p=[]
if sess: p.append(f"5h {pc(sess)}%{mark.get(sess.get('severity'),'')}")
if wk:   p.append(f"wk {pc(wk)}%{mark.get(wk.get('severity'),'')}")
for l in scoped(): p.append(f"{name(l)} {pc(l)}%{mark.get(l.get('severity'),'')}")
print(" · ".join(p) if p else "usage n/a")
PY
    ;;
  hook)
    ensure_fresh
    sid=$(session_id)
    python3 - "$CACHE" "$SEEN/$sid" <<'PY'
import json,sys,datetime
cache,state=sys.argv[1],sys.argv[2]
try: d=json.load(open(cache))
except Exception: sys.exit(0)
lims=d.get("limits") or []
def pc(l): return int(round(l.get("percent",0)))
def rem(l): return 100-pc(l)
def name(l): return (((l.get("scope") or {}).get("model") or {}).get("display_name")) or "?"
def label(l):
    if l.get("scope"): return name(l)+"(週次)"
    return {"session":"5h","weekly_all":"週次"}.get(l.get("kind",""), l.get("kind",""))
def reset_short(l):
    r=l.get("resets_at")
    if not r: return ""
    try:
        t=datetime.datetime.fromisoformat(r.replace("Z","+00:00"))
        ms=(t-datetime.datetime.now(datetime.timezone.utc)).total_seconds()
    except Exception: return ""
    if ms<=0: return "now"
    h=int(ms//3600); dd=h//24
    return f"{dd}d" if dd>0 else (f"{h}h" if h>0 else f"{int(ms//60)}m")
RANK={"normal":0,"warning":1,"critical":2}
hot=[l for l in lims if RANK.get(l.get("severity"),0)>=1]
if not hot:
    try: import os; os.remove(state)   # 落ち着いたら状態リセット
    except OSError: pass
    sys.exit(0)
trigger=min(rem(l) for l in hot)            # 最も逼迫した窓の残量
sevrank=max(RANK.get(l.get("severity"),0) for l in hot)
# 前回注入時の (残量, sevrank)
last_rem, last_sev = None, -1
try:
    a,b=open(state).read().split(); last_rem=float(a); last_sev=int(b)
except Exception: pass
step = 1 if trigger<=10 else 5              # 残10%以下は1%刻み、それ以上は5%刻み
inject = (last_rem is None) or (sevrank>last_sev) or ((last_rem-trigger)>=step)
if not inject: sys.exit(0)
open(state,"w").write(f"{trigger} {sevrank}")
lines=[f"- {label(l)}: {pc(l)}% 使用 / 残 {rem(l)}% ({l.get('severity')}, {reset_short(l)}でリセット)" for l in sorted(hot,key=rem)]
print("[Claude 利用枠 警告] 以下の枠が逼迫。ORG.md の方針に従い、逼迫モデル(特にFable)の使用は必要な場面に限定すること:")
print("\n".join(lines))
PY
    ;;
  raw)        ensure_fresh; [ -f "$CACHE" ] && python3 -m json.tool "$CACHE" || echo '{}' ;;
  *) echo "usage: claude-usage {statusline|hook|raw|refresh}" >&2; exit 1 ;;
esac
